services:
  mosdns:
    image: your-dockerhub-user/mosdns:v0.5.1
    container_name: mosdns
    restart: unless-stopped
    # If your upstream/proxy companion runs on the Docker host,
    # add host-gateway mapping and update /cus/mosdns config to use
    # host.docker.internal instead of 127.0.0.1.
    # extra_hosts:
    #   - "host.docker.internal:host-gateway"
    ports:
      - "53:53/tcp"
      - "53:53/udp"
      - "9099:9099/tcp"
    volumes:
      - ./mosdns-data:/cus/mosdns
