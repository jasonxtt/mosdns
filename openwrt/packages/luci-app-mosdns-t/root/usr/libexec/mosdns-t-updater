#!/bin/sh

CHECK_STATE='/tmp/mosdns-t-update-checked'
DEFAULT_REPO_URLS='https://jasonxtt.github.io/mosdns
https://raw.githubusercontent.com/jasonxtt/mosdns/openwrt-feed
https://ghproxy.net/https://raw.githubusercontent.com/jasonxtt/mosdns/openwrt-feed
https://cdn.jsdelivr.net/gh/jasonxtt/mosdns@openwrt-feed'
REPO_URLS="${MOSDNS_T_REPO_URLS:-${MOSDNS_T_REPO_URL:-$DEFAULT_REPO_URLS}}"
SELECTED_REPO_URL=''

select_repository() {
	index_path="$1"
	key_path="$2"
	key_file="$3"
	index_tmp="/tmp/mosdns-t-repository-index.$$"
	key_tmp="${key_file}.tmp"

	for base_url in $REPO_URLS; do
		rm -f "$index_tmp" "$key_tmp"
		if wget -q -T 15 -O "$index_tmp" "${base_url}/${index_path}" &&
			[ -s "$index_tmp" ] &&
			wget -q -T 15 -O "$key_tmp" "${base_url}/${key_path}" &&
			[ -s "$key_tmp" ]; then
			mv "$key_tmp" "$key_file"
			rm -f "$index_tmp"
			SELECTED_REPO_URL="$base_url"
			return 0
		fi
	done

	rm -f "$index_tmp" "$key_tmp"
	echo '所有 MosDNS-T 软件源均无法访问。' >&2
	return 1
}

configure_repository() {
	if command -v apk >/dev/null 2>&1; then
		arch="$(apk --print-arch)"
		key_file='/etc/apk/keys/mosdns-t.pem'
		repository_file='/etc/apk/repositories.d/mosdns-t.list'
		mkdir -p /etc/apk/keys /etc/apk/repositories.d
		select_repository "packages/25.12/${arch}/packages.adb" 'keys/mosdns-t.pem' "$key_file" || return 1
		printf '%s\n' "${SELECTED_REPO_URL}/packages/25.12/${arch}/packages.adb" > "$repository_file"
	else
		arch="$(opkg print-architecture | awk '$1 == "arch" && $3 + 0 >= priority { arch = $2; priority = $3 + 0 } END { print arch }')"
		[ -n "$arch" ] || {
			echo '无法识别 OpenWrt 软件包架构。' >&2
			return 1
		}
		key_file='/etc/opkg/keys/e876ba860888cd76'
		custom_feeds='/etc/opkg/customfeeds.conf'
		mkdir -p /etc/opkg/keys
		select_repository "packages/24.10/${arch}/Packages.gz" 'keys/mosdns-t.pub' "$key_file" || return 1
		[ -f "$custom_feeds" ] || : > "$custom_feeds"
		sed -i '/^src\/gz mosdns_t /d' "$custom_feeds"
		printf 'src/gz mosdns_t %s/packages/24.10/%s\n' "$SELECTED_REPO_URL" "$arch" >> "$custom_feeds"
	fi
}

package_version() {
	if command -v apk >/dev/null 2>&1; then
		apk list --installed "$1" 2>/dev/null | sed -n "s/^$1-\([^ ]*\).*/\1/p" | head -n 1
	else
		opkg list-installed "$1" 2>/dev/null | awk 'NR == 1 { print $3 }'
	fi
}

package_update() {
	configure_repository || return 1
	if command -v apk >/dev/null 2>&1; then
		apk update
	else
		opkg update
	fi
}

package_upgrade() {
	if command -v apk >/dev/null 2>&1; then
		apk add --upgrade mosdns-t luci-app-mosdns-t
	else
		opkg install mosdns-t luci-app-mosdns-t
	fi
}

print_status() {
	core_version="$(package_version mosdns-t)"
	luci_version="$(package_version luci-app-mosdns-t)"
	webui_port="$(jsonfilter -i /etc/mosdns-t/webinfo/webui_port_settings.json -e '@.port' 2>/dev/null)"
	[ -n "$webui_port" ] || webui_port="$(uci -q get mosdns-t.main.webui_port)"
	[ -n "$webui_port" ] || webui_port=9099
	config_file="$(uci -q get mosdns-t.main.configfile)"
	[ -n "$config_file" ] || config_file=/etc/mosdns-t/config_custom.yaml
	dns_port="$(sed -n 's/^[[:space:]]*listen: "127\.0\.0\.1:\([0-9][0-9]*\)".*/\1/p' "$config_file" | head -n 1)"
	[ -n "$dns_port" ] || dns_port="$(uci -q get mosdns-t.main.listen_port)"
	[ -n "$dns_port" ] || dns_port=5335
	update_available=0
	if command -v apk >/dev/null 2>&1; then
		if apk list -u 2>/dev/null | grep -Eq '^(mosdns-t|luci-app-mosdns-t)-'; then
			update_available=1
		fi
	elif opkg list-upgradable 2>/dev/null | grep -Eq '^(mosdns-t|luci-app-mosdns-t) - '; then
		update_available=1
	fi

	printf 'core_version=%s\n' "$core_version"
	printf 'luci_version=%s\n' "$luci_version"
	printf 'webui_port=%s\n' "$webui_port"
	printf 'dns_port=%s\n' "$dns_port"
	printf 'update_available=%s\n' "$update_available"
	[ -e "$CHECK_STATE" ] && printf 'update_checked=1\n' || printf 'update_checked=0\n'
}

case "$1" in
	status)
		print_status
		;;
	check)
		package_update
		: > "$CHECK_STATE"
		print_status
		;;
	upgrade)
		package_update
		: > "$CHECK_STATE"
		package_upgrade
		/etc/init.d/mosdns-t restart
		print_status
		;;
	*)
		echo "usage: $0 {status|check|upgrade}" >&2
		exit 1
		;;
esac
